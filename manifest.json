{
  "manifest_version": 3,
  "name": "Yt mini PIP",
  "version": "1.1",
  "description": "Automatically puts YouTube videos into Picture-in-Picture mode when you switch tabs.",
  "icons": {
    "16": "pip.png",
    "32": "pip.png",
    "48": "pip.png",
    "128": "pip.png"
  },
  "permissions": ["activeTab", "scripting", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "host_permissions": ["*://*.youtube.com/*"]
}
